{
  "name": "philtou.com",
  "private": true,
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "predev": "node scripts/ensure-assets.mjs",
    "dev": "ARCHIVE_DEV=1 node scripts/dev.mjs",
    "dev:lan": "ARCHIVE_DEV=1 node scripts/dev.mjs",
    "dev:home": "npm run dev --prefix apps/home",
